# Перелік змінних середовища, які читає сервер (process.env).
# Для localhost дефолти працюють і без налаштувань — це лише довідка.
# Щоб задати: PowerShell  ->  $env:JWT_SECRET="..."; npm start
#             bash        ->  JWT_SECRET="..." npm start

# Секрет для підпису JWT. У проді — довгий випадковий рядок.
JWT_SECRET=change-me-to-a-long-random-string

# Порт Node-сервера (за замовчуванням 3000).
PORT=3000

# Шлях до файлу SQLite (за замовчуванням server/game.db). ':memory:' — у тестах.
# DB_PATH=./server/game.db
